  @svon.node_append_child(el119, t120)
  @svon.node_append_child(el118, el119)
  let el121 : @svon.DomNode = @svon.document_create_element("button")
  @svon.node_add_event_listener(el121, "click", stress_jump)
  let t122 : @svon.DomNode = @svon.document_create_text_node("+100")
  @svon.node_append_child(el121, t122)
  @svon.node_append_child(el118, el121)
  @svon.node_append_child(el105, el118)
  @svon.node_append_child(el0, el105)
  @svon.node_append_child(root, el0)
  let el123 : @svon.DomNode = @svon.document_create_element("div")
  @svon.node_set_attribute(el123, "class", "row")
  let el124 : @svon.DomNode = @svon.document_create_element("span")
  @svon.node_set_attribute(el124, "class", "label")
  let t125 : @svon.DomNode = @svon.document_create_text_node("Doubled:")
  @svon.node_append_child(el124, t125)
  @svon.node_append_child(el123, el124)
  let el126 : @svon.DomNode = @svon.document_create_element("span")
  @svon.node_set_attribute(el126, "class", "value")
  let t127 : @svon.DomNode = @svon.document_create_text_node("")
  @svon.node_append_child(el126, t127)
  let _ = @svon.effect(fn() {
    @svon.node_set_text_content(t127, doubled.get().to_string())
    Option::None
  })
  @svon.node_append_child(el123, el126)
  @svon.node_append_child(root, el123)
  let el128 : @svon.DomNode = @svon.document_create_element("div")
  @svon.node_set_attribute(el128, "class", "row")
  let el129 : @svon.DomNode = @svon.document_create_element("span")
