  @svon.node_append_child(root, el128)
  let el133 : @svon.DomNode = @svon.document_create_element("div")
  @svon.node_set_attribute(el133, "class", "buttons")
  let el134 : @svon.DomNode = @svon.document_create_element("button")
  @svon.node_add_event_listener(el134, "click", dec)
