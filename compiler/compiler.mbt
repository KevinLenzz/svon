///|
/// Svon template compiler — converts `.svon` files into MoonBit source.

///|
/// Compile a single `.svon` source string into a complete MoonBit program.
///
/// This is the simplest entry point: it parses the SVON template markup and
/// emits a single `main.mbt` file as a `String`.  The generated code imports
/// the Svon runtime (`username/svon/core`) and calls the layout builder to
/// render the described UI.
///
/// If the template contains parse errors, the output will be a commented
/// error report instead of valid MoonBit code, so the build fails with a
/// clear diagnostic message.
///
/// # Parameters
/// - `source` : The raw text content of a `.svon` file.
///
/// # Returns
/// A MoonBit source string (full `main.mbt`) ready to be written to disk.
///
/// # See also
/// - `generate_project` for also producing `index.html` and `moon.pkg.json`.
pub fn compile(source : String) -> String {
  let template = parse(source)
  if template.diagnostics.length() > 0 {
    let b = StringBuilder::new()
    b.write_string("// ==========================================================\n")
    b.write_string("// Svon compilation failed with ")
    b.write_string(template.diagnostics.length().to_string())
    b.write_string(" error(s):\n")
    b.write_string("//\n")
    b.write_string(format_diagnostics(source, template.diagnostics))
    b.write_string("//\n")
    b.write_string("// ==========================================================\n")
    b.write_string("\n")
    b.write_string("fn main {\n")
    b.write_string("  let _svon_compile_error : Int = \"Fix the errors above in your .svon template\"\n")
    b.write_string("}\n")
    b.to_string()
  } else {
    generate(template, false)
  }
}

///|
/// Compile a template in standalone mode — the generated output does not
/// reference `@svon.*`, so it can be built without an external svon package
/// dependency.  Use when bundling the svon runtime files alongside the
/// generated `main.mbt` in the same MoonBit package.
pub fn compile_standalone(source : String) -> String {
  let template = parse(source)
  if template.diagnostics.length() > 0 {
    compile(source)
  } else {
    generate(template, true)
  }
}

///|
/// Generate a complete MoonBit project scaffold from a single `.svon` source.
///
/// Unlike `compile` which only returns the MoonBit source, this function
/// returns a 3-tuple containing everything needed to build and serve a Svon
/// application:
///
/// # Tuple fields
/// 1. **main_mbt** — The compiled MoonBit source (`main.mbt`).
/// 2. **index_html** — A minimal HTML shell that loads the compiled JS.
/// 3. **moon_pkg** — The `moon.pkg.json` snippet declaring the Svon dependency
///    and any additional imports defined in the template.
///
/// # Parameters
/// - `source` : Raw `.svon` file content.
/// - `app_name` : Human-readable application name used in the HTML `<title>`.
///
/// # Returns
/// `(main_mbt, index_html, moon_pkg)` — all three as `String`.
pub fn generate_project(source : String, app_name : String) -> (String, String, String) {
  let template = parse(source)
  let main_mbt = generate(template, false)
  let index_html = generate_html(app_name)
  let moon_pkg = generate_pkg(template.imports)
  (main_mbt, index_html, moon_pkg)
}

///|
/// Extract the `moon.pkg.json` content for a template without building the
/// full project.
///
/// Useful when you already have a compiled `main.mbt` and only need to
/// regenerate the package manifest (for example, after adding imports).
///
/// # Parameters
/// - `source` : Raw `.svon` file content (used only for its `imports` block).
///
/// # Returns
/// A `moon.pkg.json` snippet as a `String`.
pub fn generate_pkg_for_template(source : String) -> String {
  let template = parse(source)
  generate_pkg(template.imports)
}

///|
/// Compile all .svon files from a directory into a merged MoonBit project.
///
/// When a user has multiple `.svon` pages that should be served together
/// (e.g. `home.svon`, `about.svon`, `contact.svon`), this function:
///
/// 1. Compiles each page individually.
/// 2. Strips the `fn main { ... }` wrapper from each page's generated code
///    (see `strip_main_wrapper`).
/// 3. Concatenates all page bodies inside a single `fn main { ... }` block.
/// 4. Generates a shared `moon.pkg.json` with the default Svon import and
///    an `index.html` shell.
///
/// # Parameters
/// - `pages` : An array of raw `.svon` source strings, one per page.
///
/// # Returns
/// `(merged_main_mbt, moon_pkg, index_html)` — all three as `String`.
///
/// # Notes
/// The output `main.mbt` starts with a generated-by comment:
/// `/// Generated by svonc — merged from multiple pages`
pub fn build_dir(pages : Array[String]) -> (String, String, String) {
  let main_body = StringBuilder::new()
  main_body.write_string("/// Generated by svonc — merged from multiple pages\n")
  main_body.write_string("fn main {\n")

  // Compile each page, strip its outer fn main wrapper, and append the body
  for i in 0..<pages.length() {
    let src = pages[i]
    let template = parse(src)
    let body = generate(template, false)
    let inner = strip_main_wrapper(body)
    main_body.write_string(inner)
    main_body.write_string("\n")
  }

  main_body.write_string("}\n")
  let main_mbt = main_body.to_string()
  let pkg = generate_pkg_default()
  let html = generate_html("svon-pages")
  (main_mbt, pkg, html)
}

///|
/// Strip the outer `fn main { ... }` wrapper from compiled MoonBit output
/// so that multiple pages can be merged into a single `fn main` block.
///
/// Each page compiled via `generate` produces a complete `fn main { ... }`
/// block.  When merging multiple pages (see `build_dir`), we need to extract
/// only the body statements, discarding the wrapper.
///
/// # Algorithm
/// 1. Locate the `fn main {` marker in the source string.
/// 2. Extract everything after `fn main {` to the end of the string.
/// 3. If the result ends with a closing `}`, remove it.
/// 4. If `fn main {` is not found, return the original string unchanged
///    (the page may not have generated a `fn main` wrapper).
///
/// # Parameters
/// - `code` : A compiled MoonBit source string (output of `generate`).
///
/// # Returns
/// The body content with the `fn main {` header and trailing `}` removed.
fn strip_main_wrapper(code : String) -> String {
  match code.find("fn main {") {
    Option::Some(start) => {
      // Skip past "fn main {" plus the following newline
      let body_start = start + "fn main {".length() + 1
      let trimmed = code.unsafe_substring(start=body_start, end=code.length())
      // Remove trailing closing brace if present
      if trimmed.length() > 1 && trimmed.unsafe_substring(start=trimmed.length() - 1, end=trimmed.length()) == "}" {
        trimmed.unsafe_substring(start=0, end=trimmed.length() - 1)
      } else {
        trimmed
      }
    }
    Option::None => code
  }
}

///|
/// Generate the default `moon.pkg.json` content with only the Svon runtime
/// import and no additional template-level imports.
///
/// Used by `build_dir` when merging multiple pages — since each page may
/// declare different imports, the merged project falls back to a baseline
/// manifest that only depends on `username/svon`.
fn generate_pkg_default() -> String {
  "import {\n  \"username/svon/core\" @svon,\n}\nsupported_targets = \"js\"\noptions(\n  \"is-main\": true,\n)\n"
}

///|
/// Generate a minimal `index.html` shell that loads the compiled MoonBit JS.
///
/// The generated HTML:
/// - Sets the page title to `{app_name} — Svon App`.
/// - Includes an inline SVG favicon (a purple rounded-rectangle with "SV").
/// - Loads the MoonBit debug build output at
///   `../../_build/js/debug/build/cmd/MAIN/main.js`.  This relative path
///   assumes the standard MoonBit project layout where `index.html` sits in
///   the project root and the build output is two directories up.
///
/// # Parameters
/// - `app_name` : Display name inserted into `<title>`.
///
/// # Returns
/// A complete HTML5 document as a `String`.
fn generate_html(app_name : String) -> String {
  let b = StringBuilder::new()
  b.write_string("<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n")
  b.write_string("  <meta charset=\"utf-8\">\n")
  b.write_string("  <link rel=\"icon\" href=\"data:image/svg+xml,")
  b.write_string("<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 32 32%22>")
  b.write_string("<rect width=%2232%22 height=%2232%22 rx=%226%22 fill=%22%238b5cf6%22/>")
  b.write_string("<text x=%2216%22 y=%2222%22 text-anchor=%22middle%22 fill=%22white%22 font-size=%2218%22 font-weight=%22bold%22>SV</text></svg>\">\n")
  b <+ "  <title>\{app_name} — Svon App</title>\n"
  b.write_string("</head>\n<body>\n")
  b.write_string("  <script src=\"../../_build/js/debug/build/cmd/MAIN/main.js\"></script>\n")
  b.write_string("</body>\n</html>\n")
  b.to_string()
}

///|
/// Generate the `moon.pkg.json` content for a template, including both the
/// mandatory Svon runtime import and any additional imports declared in the
/// template's `imports` field.
///
/// # Input format
/// The `imports` parameter is a semicolon-delimited string of MoonBit import
/// declarations, e.g.:
/// ```
/// "\"username/mylib\" @mylib;\"username/utils\" @utils"
/// ```
///
/// # Output format
/// The generated package manifest always includes:
/// ```json
/// import {
///   "username/svon/runtime" @svon,
///   // ... any template-level imports ...
/// }
/// supported_targets = "js"
/// options(
///   "is-main": true,
/// )
/// ```
///
/// If `imports` is empty, only the Svon runtime import is emitted.
///
/// # Parameters
/// - `imports` : Semicolon-separated import declarations from the template.
///
/// # Returns
/// The `moon.pkg.json` content as a `String`.
fn generate_pkg(imports : String) -> String {
  let b = StringBuilder::new()
  if imports.length() > 0 {
    b.write_string("import {\n")
    b.write_string("  \"username/svon/core\" @svon,\n")
    let parts = imports.split(";")
    for part in parts {
      let trimmed = part.to_owned().trim().to_owned()
      if trimmed.length() > 0 {
        b.write_string("  ")
        b.write_string(trimmed)
        b.write_string(",\n")
      }
    }
    b.write_string("}\n")
  } else {
    b.write_string("import {\n  \"username/svon/core\" @svon,\n}\n")
  }
  b.write_string("supported_targets = \"js\"\n")
  b.write_string("options(\n  \"is-main\": true,\n)\n")
  b.to_string()
}
