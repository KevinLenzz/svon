///|
/// Code generator — transforms a parsed `Template` AST into MoonBit source.
///
/// This module defines:
/// - `generate` : the main entry point that takes a full `Template` AST and
///   produces a complete, compilable MoonBit source string.
/// - `generate_script` / `transform_line` : helpers that rewrite the `<script>`
///   block so that shorthand reactive primitives (`state(`, `derived(`, `effect(`)
///   are expanded to their fully-qualified forms (`@svon.state(`, …).
/// - `generate_nodes` / `generate_text` / `generate_element` : recursive
///   walkers that emit imperative MoonBit code to construct and wire up the
///   DOM tree declared in the `<template>` section.
/// - `generate_style_injection` : generates code that injects a `<style>`
///   element into the document `<head>` containing the user's compiled CSS.

///|
/// `generate(t)` is the top-level entry point of the code-generator.
///
/// It consumes a parsed `Template` and returns a `String` containing the
/// complete MoonBit source for that template.  The generated code:
///
/// 1. Opens the `main` function.
/// 2. Copies the (transformed) `<script>` block inline.
/// 3. If the template has CSS, injects a run-time `<style>` element.
/// 4. Creates the root DOM node (`<div id="root">` or similar).
/// 5. Recursively emits all child DOM nodes under that root.
/// 6. Appends the root node to `document.body`.
/// 7. Closes the `main` function.
///
/// The output is meant to be fed directly to the MoonBit compiler or REPL.
pub fn generate(t : Template, standalone : Bool) -> String {
  let b = StringBuilder::new()
  b.write_string("/// Generated by Svon compiler\n")

  // ── Phase 1: Collect static templates ─────────────────────────────
  let templates = Array::new(capacity=8)
  let template_ids = Ref(0)
  collect_templates(t.nodes, templates, template_ids)

  // ── Emit static template declarations (module-level, parsed once) ──
  for i in 0..<templates.length() {
    let prefix = if standalone { "" } else { "@svon." }
    b.write_string("let _t")
    b.write_string(i.to_string())
    b.write_string(" : ")
    b.write_string(prefix)
    b.write_string("DomNode = ")
    b.write_string(prefix)
    b.write_string("template_from_html(\"")
    b.write_string(escape_mbt(templates[i]))
    b.write_string("\")\n")
  }

  // ── Main function ────────────────────────────────────────────────
  b.write_string("fn main {\n")

  // ── Script block ──────────────────────────────────────────────────
  generate_script(t.script, b, standalone, t.script_start_line)

  // ── Suppress unused warnings for template-used functions ───────────
  suppress_unused(t.nodes, b, t.script)

  // ── Style injection ───────────────────────────────────────────────
  if t.styles.length() > 0 {
    generate_style_injection(t.styles, b, standalone)
  }

  // ── DOM construction ──────────────────────────────────────────────
  let el_id = Ref(0)

  // Create the outermost container element (always a `<div>`).
  let prefix = if standalone { "" } else { "@svon." }
  b <+
    "  let root : \{prefix}DomNode = \{prefix}document_create_element(\"div\")\n"

  // Recursively walk the parsed HTML tree and emit MoonBit statements
  // that build the corresponding DOM subtree.
  generate_nodes(t.nodes, "root", b, el_id, templates, standalone)

  // Append the fully-constructed root node to the live document body.
  b <+ "  let body = \{prefix}document_body()\n"
  b <+ "  \{prefix}node_append_child(body, root)\n"

  // Close the `main` function and return the accumulated source string.
  b.write_string("}\n")
  if standalone {
    b.to_string().replace_all(old="@svon.", new="")
  } else {
    b.to_string()
  }
}

///|
/// `generate_script` takes the raw text inside the `<script>` block and
/// emits it line-by-line into the generated `main` function, after each
/// line has been transformed by `transform_line`.
///
/// Parameters:
/// - `script` : the verbatim script source (a single string potentially
///   containing multiple lines).
/// - `b`      : the `StringBuilder` into which the transformed lines are
///   written.
fn generate_script(
  script : String,
  b : StringBuilder,
  standalone : Bool,
  script_start_line : Int,
) -> Unit {
  let raw_lines = script.split("\n")
  let mut line_index = 0
  for line in raw_lines {
    let s = line.to_owned()
    let trimmed = s.trim().to_owned()
    let transformed = transform_line(trimmed, standalone)
    if transformed.length() > 0 {
      b.write_string("  ")
      b.write_string(transformed)
      b.write_string(" // @svon-line:")
      b.write_string((script_start_line + line_index).to_string())
      b.write_string("\n")
    }
    line_index = line_index + 1
  }
}

///|
/// `transform_line` rewrites a single line of `<script>` text so that
/// short-hand reactive primitives are expanded to fully-qualified
/// `@svon.*` invocations.
///
/// Rules applied:
/// - `state(`   → `@svon.state(`
/// - `derived(` → `@svon.derived(`
/// - `effect(`  → `@svon.effect(`
///
/// Lines that are entirely whitespace (after trimming) are suppressed by
/// returning an empty string, causing the caller to skip them.
///
/// Lines starting with `//` (MoonBit comments) pass through unchanged so
/// the programmer's comments are preserved in the generated output.
fn transform_line(line : String, standalone : Bool) -> String {
  // Suppress blank lines — they would add unnecessary vertical space in
  // the output.
  if line == "" {
    return ""
  }
  // Comment lines are emitted verbatim (the leading `//` already
  // qualifies them as valid MoonBit comments).
  if line.has_prefix("//") {
    return line
  }
  if standalone {
    line
  } else {
    // Otherwise, perform the three shorthand→qualified substitutions.
    let mut result = line
    result = result.replace_all(old="state(", new="@svon.state(")
    result = result.replace_all(old="derived(", new="@svon.derived(")
    result = result.replace_all(old="effect(", new="@svon.effect(")
    result = result.replace_all(old="DomNode", new="@svon.DomNode")
    result = result.replace_all(old="dom_debug(", new="@svon.dom_debug(")
    result = result.replace_all(old="console.log(", new="@svon.console_log(")
    result = result.replace_all(old="console.info(", new="@svon.console_info(")
    result = result.replace_all(old="console.warn(", new="@svon.console_warn(")
    result = result.replace_all(old="console.error(", new="@svon.console_info(")
    result = result.replace_all(old="console.debug(", new="@svon.console_info(")
    result
  }
}

///|
/// `generate_nodes` walks a heterogenous array of `HtmlNode` values
/// (which may be either raw text or HTML elements) and dispatches each
/// one to the appropriate code-generation helper.
fn generate_nodes(
  nodes : Array[HtmlNode],
  parent : String,
  b : StringBuilder,
  el_id : Ref[Int],
  templates : Array[String],
  standalone : Bool,
) -> Unit {
  for i in 0..<nodes.length() {
    let node = nodes[i]
    match node {
      HtmlNode::Text(chunk) =>
        generate_text(chunk, parent, b, el_id, standalone)
      HtmlNode::Element(el) =>
        generate_element(el, parent, b, el_id, templates, standalone)
      HtmlNode::If(block) =>
        generate_if(block, parent, b, el_id, templates, standalone)
      HtmlNode::For(block) =>
        generate_for(block, parent, b, el_id, templates, standalone)
    }
  }
}

///|
/// `generate_text` emits MoonBit code for a single text node in the DOM.
///
/// Two cases are handled:
/// 1. **Static text** — the text content is known at compile time; a
///    text node is created with that exact content and appended to the
///    parent.
/// 2. **Dynamic expression** — the text content is computed at run time
///    via a MoonBit expression.  The generated code:
///    a. Creates an empty text node (placeholder).
///    b. Appends it to the parent so it occupies a stable position in the
///       child list.
///    c. Wraps a reactive `@svon.effect(…)` around the expression; every
///       time the expression's dependencies change the text node's content
///       is updated via `node_set_text_content(…, expr.to_string())`.
///
/// Parameters:
/// - `chunk`  : the parsed text-chunk AST node (either static or expr).
/// - `parent` : the MoonBit variable name of the parent DOM node.
/// - `b`      : the shared `StringBuilder` for the generated code.
/// - `el_id`  : a shared mutable counter for generating unique variable
///   names (each text node gets its own `t0`, `t1`, …).
fn generate_text(
  chunk : TextChunk,
  parent : String,
  b : StringBuilder,
  el_id : Ref[Int],
  standalone : Bool,
) -> Unit {
  // Allocate a unique numeric suffix for this text node's variable name.
  let id = el_id.val
  el_id.val = id + 1
  let id_str = id.to_string()
  let prefix = if standalone { "" } else { "@svon." }

  match chunk {
    // ── Static text ─────────────────────────────────────────────────
    TextChunk::Static(s) => {
      b <+
        "  let t\{id_str} : \{prefix}DomNode = \{prefix}document_create_text_node(\"\{s}\")\n"
      b <+ "  \{prefix}node_append_child(\{parent}, t\{id_str})\n"
    }
    // ── Dynamic expression ──────────────────────────────────────────
    TextChunk::Expr(expr) => {
      b <+
        "  let t\{id_str} : \{prefix}DomNode = \{prefix}document_create_text_node(\"\")\n"
      b <+ "  \{prefix}node_append_child(\{parent}, t\{id_str})\n"
      b <+ "        let _ = \{prefix}effect(fn() {\n"
      b <+
        "    \{prefix}node_set_text_content(t\{id_str}, (\{expr}).to_string())\n"
      b <+ "    Option::None\n"
      b <+ "  })\n"
    }
  }
}

///|
fn generate_element(
  el : ElementNode,
  parent : String,
  b : StringBuilder,
  el_id : Ref[Int],
  templates : Array[String],
  standalone : Bool,
) -> Unit {
  let id = el_id.val
  el_id.val = id + 1
  let el_var = "el" + id.to_string()
  let prefix = if standalone { "" } else { "@svon." }

  // If fully static, use pre-compiled template clone (single native op)
  if is_static_element(el) {
    let html = element_to_html(el)
    let mut tid = -1
    for i in 0..<templates.length() {
      if templates[i] == html {
        tid = i
        break
      }
    }
    if tid == -1 {
      tid = templates.length()
      templates.push(html)
    }
    b <+ "  let \{el_var} = \{prefix}template_clone_content(_t\{tid})\n"
    b <+ "  \{prefix}node_append_child(\{parent}, \{el_var})\n"
    return
  }

  // Dynamic element — imperative construction
  b <+
    "  let \{el_var} : \{prefix}DomNode = \{prefix}document_create_element(\"\{el.tag}\")\n"

  // ── Attributes ──────────────────────────────────────────────────
  for i in 0..<el.attributes.length() {
    let attr = el.attributes[i]
    match attr {
      Attribute::Static(name, value) =>
        b <+
          "  \{prefix}node_set_attribute(\{el_var}, \"\{name}\", \"\{value}\")\n"
      Attribute::Event(event, handler) =>
        b <+
          "  \{prefix}node_add_event_listener(\{el_var}, \"\{event}\", \{handler_prefix(handler)})\n"
      Attribute::Bind(attr_name, expr) => {
        if attr_name == "this" {
          let st_var = bind_state_var(expr)
          if st_var != expr && st_var.length() > 0 {
            b <+ "  \{st_var}.set(Option::Some(\{el_var}))\n"
          } else {
            b <+ "  \{expr} = Option::Some(\{el_var})\n"
          }
        } else if attr_name == "value" {
          b <+ "        let _ = \{prefix}effect(fn() {\n"
          b <+ "    \{prefix}node_set_value(\{el_var}, (\{expr}).to_string())\n"
          b <+ "    Option::None\n"
          b <+ "  })\n"
        } else if attr_name == "open" {
          b <+ "        let _ = \{prefix}effect(fn() {\n"
          b <+ "    \{prefix}node_set_open(\{el_var}, (\{expr}))\n"
          b <+ "    Option::None\n"
          b <+ "  })\n"
        } else {
          b <+ "        let _ = \{prefix}effect(fn() {\n"
          b <+
            "    \{prefix}node_set_attribute(\{el_var}, \"\{attr_name}\", (\{expr}).to_string())\n"
          b <+ "    Option::None\n"
          b <+ "  })\n"
        }
        let st_var = bind_state_var(expr)
        let event = bind_event(attr_name)
        let getter = bind_getter(el, attr_name)
        if st_var.length() > 0 && event.length() > 0 && getter.length() > 0 {
          b <+
            "  \{prefix}node_add_event_listener(\{el_var}, \"\{event}\", fn() {\n"
          b <+ "    \{st_var}.set(\{prefix}\{getter}(\{el_var}))\n"
          b.write_string("  })\n")
        }
      }
    }
  }

  // ── Children ────────────────────────────────────────────────────
  generate_nodes(el.children, el_var, b, el_id, templates, standalone)

  // ── Attach to parent ────────────────────────────────────────────
  b <+ "  \{prefix}node_append_child(\{parent}, \{el_var})\n"
}

///|
/// Check whether an element and all its descendants are fully static
/// (no event handlers, no reactive bindings, no expression children).
fn is_static_element(el : ElementNode) -> Bool {
  for i in 0..<el.attributes.length() {
    match el.attributes[i] {
      Attribute::Static(_, _) => continue
      _ => return false
    }
  }
  for i in 0..<el.children.length() {
    match el.children[i] {
      HtmlNode::Text(TextChunk::Expr(_)) => return false
      HtmlNode::Text(TextChunk::Static(_)) => continue
      HtmlNode::Element(child) =>
        if !is_static_element(child) {
          return false
        } else {
          continue
        }
      HtmlNode::If(_) => return false
      HtmlNode::For(_) => return false
    }
  }
  true
}

///|
/// Serialize a static element and its children to an HTML string.
fn element_to_html(el : ElementNode) -> String {
  let b = StringBuilder::new()
  b.write_string("<")
  b.write_string(el.tag)
  for i in 0..<el.attributes.length() {
    match el.attributes[i] {
      Attribute::Static(name, value) => {
        b.write_string(" ")
        b.write_string(name)
        b.write_string("=\"")
        b.write_string(escape_html(value))
        b.write_string("\"")
      }
      _ => ()
    }
  }
  b.write_string(">")
  for i in 0..<el.children.length() {
    match el.children[i] {
      HtmlNode::Text(TextChunk::Static(s)) => b.write_string(escape_html(s))
      HtmlNode::Text(TextChunk::Expr(_)) => b.write_string(" ")
      HtmlNode::Element(child) => b.write_string(element_to_html(child))
      HtmlNode::If(_) => b.write_string(" ")
      HtmlNode::For(_) => b.write_string(" ")
    }
  }
  b.write_string("</")
  b.write_string(el.tag)
  b.write_string(">")
  b.to_string()
}

///|
/// Escape a string for safe embedding in a MoonBit string literal.
fn escape_mbt(s : String) -> String {
  s
  .replace_all(old="\\", new="\\\\")
  .replace_all(old="\"", new="\\\"")
  .replace_all(old="\n", new="\\n")
}

///|
/// Collect function names referenced in template expressions and emit
/// dummy references to suppress MoonBit "unused function" warnings.
fn suppress_unused(
  nodes : Array[HtmlNode],
  b : StringBuilder,
  script : String,
) -> Unit {
  let calls = Array::new(capacity=4)
  collect_calls(nodes, calls)
  for i in 0..<calls.length() {
    let name = calls[i]
    // Only suppress if the function is defined in the script
    if script.contains("fn " + name + "(") ||
      script.contains("fn " + name + " ") {
      b.write_string("  let _svon_ref_")
      b.write_string(name)
      b.write_string(" = ")
      b.write_string(name)
      b.write_string("\n")
    }
  }
}

///|
/// Recursively collect function call names from template expressions.
fn collect_calls(nodes : Array[HtmlNode], calls : Array[String]) -> Unit {
  for i in 0..<nodes.length() {
    match nodes[i] {
      HtmlNode::Text(TextChunk::Expr(expr)) => {
        let val = expr
        collect_fn_names(val, calls)
      }
      HtmlNode::Text(TextChunk::Static(_)) => ()
      HtmlNode::Element(el) => {
        // Check event handlers like onclick={bump}
        for j in 0..<el.attributes.length() {
          match el.attributes[j] {
            Attribute::Event(_, handler) => calls.push(handler)
            _ => ()
          }
        }
        collect_calls(el.children, calls)
      }
      HtmlNode::If(block) => {
        collect_calls(block.body, calls)
        for j in 0..<block.else_ifs.length() {
          collect_calls(block.else_ifs[j].body, calls)
        }
        collect_calls(block.else_body, calls)
      }
      HtmlNode::For(block) => collect_calls(block.body, calls)
    }
  }
}

///|
/// Extract function names from expressions like "aaa()", "foo.bar()", "baz().x".
fn collect_fn_names(expr : String, calls : Array[String]) -> Unit {
  let s = expr
  let mut i = 0
  while i < s.length() {
    // Find identifier followed by "("
    if s[i] >= 65 && s[i] <= 122 {
      let mut j = i + 1
      while j < s.length() && ((s[j] >= 48 && s[j] <= 122) || s[j] == 95) {
        j = j + 1
      }
      // Skip whitespace before "("
      let mut k = j
      while k < s.length() && s[k] == 32 {
        k = k + 1
      }
      if k < s.length() && s[k] == 40 {
        let name = s.unsafe_substring(start=i, end=j)
        if name != "fn" && name.length() > 0 {
          // Check if name is already in calls
          let mut found = false
          for x in 0..<calls.length() {
            if calls[x] == name {
              found = true
              break
            }
          }
          if !found {
            calls.push(name)
          }
        }
        i = k + 1
        continue
      }
      i = j
      continue
    }
    i = i + 1
  }
}

///|
fn escape_html(s : String) -> String {
  s
  .replace_all(old="&", new="&amp;")
  .replace_all(old="\"", new="&quot;")
  .replace_all(old="<", new="&lt;")
  .replace_all(old=">", new="&gt;")
  .replace_all(old="\n", new="\\n")
}

///|
/// First pass: scan the node tree and collect all static element subtrees.
fn collect_templates(
  nodes : Array[HtmlNode],
  templates : Array[String],
  template_ids : Ref[Int],
) -> Unit {
  for i in 0..<nodes.length() {
    match nodes[i] {
      HtmlNode::Element(el) =>
        if is_static_element(el) {
          let html = element_to_html(el)
          let mut found = false
          for j in 0..<templates.length() {
            if templates[j] == html {
              found = true
              break
            }
          }
          if !found {
            templates.push(html)
          }
        } else {
          collect_templates(el.children, templates, template_ids)
        }
      _ => ()
    }
  }
}

///|
/// `generate_style_injection` emits MoonBit code that, at run time:
///
/// 1. Creates a `<style>` element via `document_create_element("style")`.
/// 2. Escapes the user's CSS so it can safely appear inside a MoonBit
///    string literal.
/// 3. Sets the `<style>` element's text content to the escaped CSS.
/// 4. Retrieves the document `<head>` and appends the `<style>` element
///    to it, making the styles active in the page.
///
/// This is called only when the template contains a non-empty `<style>`
/// block.
///
/// Parameters:
/// - `css` : the full CSS source string from the `<style>` block.
/// - `b`   : the shared `StringBuilder` for the generated code.
fn generate_style_injection(
  css : String,
  b : StringBuilder,
  standalone : Bool,
) -> Unit {
  let prefix = if standalone { "" } else { "@svon." }
  b <+
    "  let style_el : \{prefix}DomNode = \{prefix}document_create_element(\"style\")\n"

  // Escape double-quotes and newlines so the CSS can be used as a
  // MoonBit string literal without breaking syntax.
  let escaped = css
    .replace_all(old="\"", new="\\\"")
    .replace_all(old="\n", new="\\n")

  // Set the CSS text as the content of the style element.
  b <+ "  \{prefix}node_set_text_content(style_el, \"\{escaped}\")\n"

  // Retrieve the document's `<head>` element.
  b <+ "  let head = \{prefix}document_head()\n"

  // Append the style element to the head so the browser applies the CSS.
  b <+ "  \{prefix}node_append_child(head, style_el)\n"
}

///|
fn generate_if(
  block : IfBlock,
  parent : String,
  b : StringBuilder,
  el_id : Ref[Int],
  templates : Array[String],
  standalone : Bool,
) -> Unit {
  let prefix = if standalone { "" } else { "@svon." }
  let id = el_id.val.to_string()
  el_id.val = el_id.val + 1
  let anchor = "_svon_a" + id
  let self_var = "_svon_s" + id
  let branch_var = "_svon_b" + id
  let num_branches = 1 + block.else_ifs.length() + 1
  b <+ "  let \{anchor} = \{prefix}document_create_comment(\"#if\")\n"
  b <+ "  \{prefix}node_append_child(\{parent}, \{anchor})\n"
  for j in 0..<num_branches {
    let frag = self_var + "_" + j.to_string()
    b <+ "  let \{frag} = \{prefix}document_create_container()\n"
    if j == 0 {
      generate_nodes(block.body, frag, b, el_id, templates, standalone)
    } else if j <= block.else_ifs.length() {
      generate_nodes(
        block.else_ifs[j - 1].body,
        frag,
        b,
        el_id,
        templates,
        standalone,
      )
    } else {
      generate_nodes(block.else_body, frag, b, el_id, templates, standalone)
    }
  }
  b <+ "  let \{branch_var} = Ref(0)\n"
  b.write_string("  ")
  for j in 0..<num_branches {
    let frag = self_var + "_" + j.to_string()
    let cond = if j == 0 {
      block.condition
    } else if j <= block.else_ifs.length() {
      block.else_ifs[j - 1].condition
    } else {
      "true"
    }
    if j == 0 {
      b.write_string("if ")
    } else {
      b.write_string(" else if ")
    }
    b <+ "\{cond} {\n"
    b <+ "    \{prefix}node_insert_before(\{parent}, \{frag}, \{anchor})\n"
    b <+ "    \{branch_var}.val = \{j}\n"
    b.write_string("  }")
  }
  b.write_string("\n")
  b <+ "        let _ = \{prefix}effect(fn() {\n"
  b.write_string("    let _svon_new = ")
  for j in 0..<num_branches {
    let cond = if j == 0 {
      block.condition
    } else if j <= block.else_ifs.length() {
      block.else_ifs[j - 1].condition
    } else {
      "true"
    }
    if j == 0 {
      b <+ "if \{cond} { \{j} }"
    } else {
      b <+ " else if \{cond} { \{j} }"
    }
  }
  b <+ " else { \{num_branches} }\n"
  b <+ "    if _svon_new != \{branch_var}.val {\n"
  b.write_string("      ")
  for j in 0..<num_branches {
    let frag = self_var + "_" + j.to_string()
    if j == 0 {
      b <+ "if \{branch_var}.val == 0 {"
    } else {
      b <+ " else if \{branch_var}.val == \{j} {"
    }
    b <+ " \{prefix}node_remove_child(\{parent}, \{frag}) }\n"
    if j < num_branches - 1 {
      b.write_string("      ")
    }
  }
  b.write_string("      ")
  for j in 0..<num_branches {
    let frag = self_var + "_" + j.to_string()
    if j == 0 {
      b <+ "if _svon_new == 0 {"
    } else {
      b <+ " else if _svon_new == \{j} {"
    }
    b <+ " \{prefix}node_insert_before(\{parent}, \{frag}, \{anchor}) }\n"
    if j < num_branches - 1 {
      b.write_string("      ")
    }
  }
  b <+ "      \{branch_var}.val = _svon_new\n"
  b.write_string("    }\n")
  b.write_string("    Option::None\n")
  b.write_string("  })\n")
}

///|
fn generate_for(
  block : ForBlock,
  parent : String,
  b : StringBuilder,
  el_id : Ref[Int],
  templates : Array[String],
  standalone : Bool,
) -> Unit {
  let prefix = if standalone { "" } else { "@svon." }
  let id = el_id.val.to_string()
  el_id.val = el_id.val + 1
  let anchor = "_svon_a" + id
  let containers = "_svon_c" + id
  b <+ "  let \{anchor} = \{prefix}document_create_comment(\"#for\")\n"
  b <+ "  \{prefix}node_append_child(\{parent}, \{anchor})\n"
  b <+ "  let \{containers} = Ref(Array::new())\n"
  b <+ "        let _ = \{prefix}effect(fn() {\n"
  b <+ "    for c in \{containers}.val {\n"
  b <+ "      \{prefix}node_remove_child(\{parent}, c)\n"
  b <+ "    }\n"
  b <+ "    \{containers}.val = Array::new()\n"
  b <+ "    for \{block.for_expr} {\n"
  b <+ "      let _svon_ct = \{prefix}document_create_container()\n"
  generate_nodes(block.body, "_svon_ct", b, el_id, templates, standalone)
  b <+ "      \{prefix}node_insert_before(\{parent}, _svon_ct, \{anchor})\n"
  b <+ "      \{containers}.val.push(_svon_ct)\n"
  b.write_string("    }\n")
  b.write_string("    Option::None\n")
  b.write_string("  })\n")
}

///|
fn handler_prefix(h : String) -> String {
  h
  .replace_all(old="dom_debug(", new="@svon.dom_debug(")
  .replace_all(old="console.log(", new="@svon.console_log(")
  .replace_all(old="console.warn(", new="@svon.console_warn(")
  .replace_all(old="console.error(", new="@svon.console_error(")
  .replace_all(old="console.info(", new="@svon.console_info(")
  .replace_all(old="console.debug(", new="@svon.console_debug(")
}

///|
fn bind_state_var(expr : String) -> String {
  match expr.find(".get()") {
    Option::Some(pos) => expr.unsafe_substring(start=0, end=pos)
    Option::None => expr
  }
}

///|
fn bind_event(prop : String) -> String {
  if prop == "value" {
    "input"
  } else if prop == "checked" || prop == "indeterminate" {
    "change"
  } else if prop == "open" {
    "toggle"
  } else {
    ""
  }
}

///|
fn bind_getter(el : ElementNode, prop : String) -> String {
  if prop == "value" {
    "node_get_value"
  } else if prop == "checked" {
    for attr in el.attributes {
      if attr is Attribute::Static("type", "radio") {
        return "node_get_value"
      }
    }
    "node_get_checked"
  } else if prop == "open" {
    "node_get_open"
  } else {
    ""
  }
}
