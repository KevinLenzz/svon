///|
/// Code generator — transforms a parsed `Template` AST into MoonBit source.
///
/// This module defines:
/// - `generate` : the main entry point that takes a full `Template` AST and
///   produces a complete, compilable MoonBit source string.
/// - `generate_script` / `transform_line` : helpers that rewrite the `<script>`
///   block so that shorthand reactive primitives (`state(`, `derived(`, `effect(`)
///   are expanded to their fully-qualified forms (`@svon.state(`, …).
/// - `generate_nodes` / `generate_text` / `generate_element` : recursive
///   walkers that emit imperative MoonBit code to construct and wire up the
///   DOM tree declared in the `<template>` section.
/// - `generate_style_injection` : generates code that injects a `<style>`
///   element into the document `<head>` containing the user's compiled CSS.

///|
/// `generate(t)` is the top-level entry point of the code-generator.
///
/// It consumes a parsed `Template` and returns a `String` containing the
/// complete MoonBit source for that template.  The generated code:
///
/// 1. Opens the `main` function.
/// 2. Copies the (transformed) `<script>` block inline.
/// 3. If the template has CSS, injects a run-time `<style>` element.
/// 4. Creates the root DOM node (`<div id="root">` or similar).
/// 5. Recursively emits all child DOM nodes under that root.
/// 6. Appends the root node to `document.body`.
/// 7. Closes the `main` function.
///
/// The output is meant to be fed directly to the MoonBit compiler or REPL.
pub fn generate(t : Template, standalone : Bool) -> String {
  // The output MoonBit source is accumulated in this `StringBuilder`.
  let b = StringBuilder::new()

  // Standard header that identifies the file as auto-generated.
  b.write_string("/// Generated by Svon compiler\n")

  // Open the program entry point.
  b.write_string("fn main {\n")

  // ── Script block ──────────────────────────────────────────────────
  // Transform the raw `<script>` content (shorthand → fully-qualified
  // names) and emit it inside `main`.
  generate_script(t.script, b, standalone)

  // ── Style injection ───────────────────────────────────────────────
  // If the user wrote a `<style>` block, generate code that creates a
  // `<style>` element at run time and appends it to `<head>`.
  if t.styles.length() > 0 {
    generate_style_injection(t.styles, b)
  }

  // ── DOM construction ──────────────────────────────────────────────
  // Every generated DOM node needs a unique variable name.  `el_id` is
  // a mutable counter shared across all the `generate_*` helpers.
  let el_id = Ref(0)

  // Create the outermost container element (always a `<div>`).
  b.write_string("  let root : @svon.DomNode = @svon.document_create_element(\"div\")\n")

  // Recursively walk the parsed HTML tree and emit MoonBit statements
  // that build the corresponding DOM subtree.
  generate_nodes(t.nodes, "root", b, el_id)

  // Append the fully-constructed root node to the live document body.
  b.write_string("  let body = @svon.document_body()\n")
  b.write_string("  @svon.node_append_child(body, root)\n")

  // Close the `main` function and return the accumulated source string.
  b.write_string("}\n")
  let result = b.to_string()
  if standalone {
    result.replace_all(old="@svon.", new="")
  } else {
    result
  }
}

///|
/// `generate_script` takes the raw text inside the `<script>` block and
/// emits it line-by-line into the generated `main` function, after each
/// line has been transformed by `transform_line`.
///
/// Parameters:
/// - `script` : the verbatim script source (a single string potentially
///   containing multiple lines).
/// - `b`      : the `StringBuilder` into which the transformed lines are
///   written.
fn generate_script(script : String, b : StringBuilder, standalone : Bool) -> Unit {
  // Split the script block into individual lines.  Because `String::split`
  // returns borrowed sub-slices (`StringView`) we need to explicitly
  // `.to_owned()` each line before trimming.
  let raw_lines = script.split("\n")
  for line in raw_lines {
    let s = line.to_owned()
    let trimmed = s.trim().to_owned()
    // Apply reactive-primitive rewrite rules (see `transform_line`).
    let transformed = transform_line(trimmed, standalone)
    // Suppress lines that became empty after transformation (e.g. purely
    // whitespace lines).
    if transformed.length() > 0 {
      // Indent at the top level of `main` (two spaces).
      b.write_string("  ")
      b.write_string(transformed)
      b.write_string("\n")
    }
  }
}

///|
/// `transform_line` rewrites a single line of `<script>` text so that
/// short-hand reactive primitives are expanded to fully-qualified
/// `@svon.*` invocations.
///
/// Rules applied:
/// - `state(`   → `@svon.state(`
/// - `derived(` → `@svon.derived(`
/// - `effect(`  → `@svon.effect(`
///
/// Lines that are entirely whitespace (after trimming) are suppressed by
/// returning an empty string, causing the caller to skip them.
///
/// Lines starting with `//` (MoonBit comments) pass through unchanged so
/// the programmer's comments are preserved in the generated output.
fn transform_line(line : String, standalone : Bool) -> String {
  // Suppress blank lines — they would add unnecessary vertical space in
  // the output.
  if line == "" {
    return ""
  }
  // Comment lines are emitted verbatim (the leading `//` already
  // qualifies them as valid MoonBit comments).
  if line.has_prefix("//") {
    return line
  }
  if standalone {
    line
  } else {
    // Otherwise, perform the three shorthand→qualified substitutions.
    let mut result = line
    result = result.replace_all(old="state(", new="@svon.state(")
    result = result.replace_all(old="derived(", new="@svon.derived(")
    result = result.replace_all(old="effect(", new="@svon.effect(")
    result
  }
}

///|
/// `generate_nodes` walks a heterogenous array of `HtmlNode` values
/// (which may be either raw text or HTML elements) and dispatches each
/// one to the appropriate code-generation helper.
///
/// Parameters:
/// - `nodes`  : the child nodes to emit (in document order).
/// - `parent` : the MoonBit variable name representing the parent DOM
///   node to which these children are appended.
/// - `b`      : the shared `StringBuilder` where the generated code is
///   accumulated.
/// - `el_id`  : a shared mutable counter for generating unique variable
///   names (e.g. `el0`, `el1`, …).
fn generate_nodes(
  nodes : Array[HtmlNode],
  parent : String,
  b : StringBuilder,
  el_id : Ref[Int],
) -> Unit {
  for i in 0..<nodes.length() {
    let node = nodes[i]
    match node {
      // A piece of text (static or interpolated expression).
      HtmlNode::Text(chunk) => generate_text(chunk, parent, b, el_id)
      // A standard HTML element with tag, attributes, and children.
      HtmlNode::Element(el) => generate_element(el, parent, b, el_id)
    }
  }
}

///|
/// `generate_text` emits MoonBit code for a single text node in the DOM.
///
/// Two cases are handled:
/// 1. **Static text** — the text content is known at compile time; a
///    text node is created with that exact content and appended to the
///    parent.
/// 2. **Dynamic expression** — the text content is computed at run time
///    via a MoonBit expression.  The generated code:
///    a. Creates an empty text node (placeholder).
///    b. Appends it to the parent so it occupies a stable position in the
///       child list.
///    c. Wraps a reactive `@svon.effect(…)` around the expression; every
///       time the expression's dependencies change the text node's content
///       is updated via `node_set_text_content(…, expr.to_string())`.
///
/// Parameters:
/// - `chunk`  : the parsed text-chunk AST node (either static or expr).
/// - `parent` : the MoonBit variable name of the parent DOM node.
/// - `b`      : the shared `StringBuilder` for the generated code.
/// - `el_id`  : a shared mutable counter for generating unique variable
///   names (each text node gets its own `t0`, `t1`, …).
fn generate_text(
  chunk : TextChunk,
  parent : String,
  b : StringBuilder,
  el_id : Ref[Int],
) -> Unit {
  // Allocate a unique numeric suffix for this text node's variable name.
  let id = el_id.val
  el_id.val = id + 1
  let id_str = id.to_string()

  match chunk {
    // ── Static text ─────────────────────────────────────────────────
    TextChunk::Static(s) => {
      // Create a `Text` node pre-filled with the literal string value.
      b <+ "  let t\{id_str} : @svon.DomNode = @svon.document_create_text_node(\"\{s}\")\n"
      // Append it to the parent immediately — no reactivity needed.
      b <+ "  @svon.node_append_child(\{parent}, t\{id_str})\n"
    }
    // ── Dynamic expression ──────────────────────────────────────────
    TextChunk::Expr(expr) => {
      // Create an empty text node as a placeholder.
      b <+ "  let t\{id_str} : @svon.DomNode = @svon.document_create_text_node(\"\")\n"
      // Append the placeholder to the parent so it has a fixed slot in
      // the DOM.
      b <+ "  @svon.node_append_child(\{parent}, t\{id_str})\n"
      // Register a reactive effect: whenever `expr`'s tracked state
      // changes, the text content of the placeholder is updated to the
      // stringified value of `expr`.
      b <+ "        let _ = @svon.effect(fn() {\n"
      b <+ "    @svon.node_set_text_content(t\{id_str}, \{expr}.to_string())\n"
      // `effect` expects the closure to return `Option<_>`; we return
      // `None` because this effect never cleans itself up.
      b <+ "    Option::None\n"
      b <+ "  })\n"
    }
  }
}

///|
/// `generate_element` emits MoonBit code that creates a single HTML
/// element (e.g. `<div>`, `<button>`, …) together with all of its
/// attributes and descendants.
///
/// The generated code follows this order:
/// 1. Create the element node (`document_create_element`).
/// 2. Process each attribute:
///    - `Static`  → `node_set_attribute(name, value)`.
///    - `Event`   → `node_add_event_listener(event, handler)`.
///    - `Bind`    → reactively updated via `@svon.effect(…)`.
/// 3. Recursively generate child nodes (text and nested elements).
/// 4. Append the finished element to its parent.
///
/// Parameters:
/// - `el`     : the parsed element AST node.
/// - `parent` : the MoonBit variable name of the parent DOM node.
/// - `b`      : the shared `StringBuilder` for the generated code.
/// - `el_id`  : a shared mutable counter for generating unique variable
///   names (each element gets its own `el0`, `el1`, …).
fn generate_element(
  el : ElementNode,
  parent : String,
  b : StringBuilder,
  el_id : Ref[Int],
) -> Unit {
  // Allocate a unique numeric suffix for this element's variable name.
  let id = el_id.val
  el_id.val = id + 1
  let el_var = "el" + id.to_string()

  // Create the DOM element with the given tag name.
  b <+ "  let \{el_var} : @svon.DomNode = @svon.document_create_element(\"\{el.tag}\")\n"

  // ── Attributes ──────────────────────────────────────────────────
  for i in 0..<el.attributes.length() {
    let attr = el.attributes[i]
    match attr {
      // Static attribute — a name/value pair known at compile time
      // (e.g. `class="foo"`, `id="bar"`).
      Attribute::Static(name, value) => {
        b <+ "  @svon.node_set_attribute(\{el_var}, \"\{name}\", \"\{value}\")\n"
      }
      // Event listener — the handler is a MoonBit function reference
      // (e.g. `fn(e) { … }`), emitted directly into the call.
      Attribute::Event(event, handler) => {
        b <+ "  @svon.node_add_event_listener(\{el_var}, \"\{event}\", \{handler})\n"
      }
      // Reactive binding — the attribute's value is a MoonBit expression
      // that may change over time.  The generated code wraps the update
      // in an `@svon.effect(…)` so the attribute is kept in sync with
      // the expression's tracked dependencies.
      Attribute::Bind(attr_name, expr) => {
        b <+ "        let _ = @svon.effect(fn() {\n"
        b <+ "    @svon.node_set_attribute(\{el_var}, \"\{attr_name}\", \{expr}.to_string())\n"
        // Return `Option::None` — this effect has no teardown logic.
        b <+ "    Option::None\n"
        b <+ "  })\n"
      }
    }
  }

  // ── Children ────────────────────────────────────────────────────
  // Recursively emit all child nodes (text and nested elements).  The
  // children are appended to *this* element's variable, not to the
  // parent.
  generate_nodes(el.children, el_var, b, el_id)

  // ── Attach to parent ────────────────────────────────────────────
  // After all attributes and children have been emitted, attach the
  // finished element to its parent.
  b <+ "  @svon.node_append_child(\{parent}, \{el_var})\n"
}

///|
/// `generate_style_injection` emits MoonBit code that, at run time:
///
/// 1. Creates a `<style>` element via `document_create_element("style")`.
/// 2. Escapes the user's CSS so it can safely appear inside a MoonBit
///    string literal.
/// 3. Sets the `<style>` element's text content to the escaped CSS.
/// 4. Retrieves the document `<head>` and appends the `<style>` element
///    to it, making the styles active in the page.
///
/// This is called only when the template contains a non-empty `<style>`
/// block.
///
/// Parameters:
/// - `css` : the full CSS source string from the `<style>` block.
/// - `b`   : the shared `StringBuilder` for the generated code.
fn generate_style_injection(css : String, b : StringBuilder) -> Unit {
  // Create the `<style>` DOM element.
  b.write_string("  let style_el : @svon.DomNode = @svon.document_create_element(\"style\")\n")

  // Escape double-quotes and newlines so the CSS can be used as a
  // MoonBit string literal without breaking syntax.
  let escaped = css.replace_all(old="\"", new="\\\"").replace_all(old="\n", new="\\n")

  // Set the CSS text as the content of the style element.
  b <+ "  @svon.node_set_text_content(style_el, \"\{escaped}\")\n"

  // Retrieve the document's `<head>` element.
  b.write_string("  let head = @svon.document_head()\n")

  // Append the style element to the head so the browser applies the CSS.
  b.write_string("  @svon.node_append_child(head, style_el)\n")
}
