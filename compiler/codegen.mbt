///|
/// Code generator — transforms a parsed `Template` AST into MoonBit source.

pub fn generate(t : Template) -> String {
  let b = StringBuilder::new()
  b.write_string("/// Generated by Svon compiler\n")
  b.write_string("fn main {\n")
  generate_script(t.script, b)
  if t.styles.length() > 0 {
    generate_style_injection(t.styles, b)
  }
  let el_id = Ref(0)
  b.write_string("  let root : @svon.DomNode = @svon.document_create_element(\"div\")\n")
  generate_nodes(t.nodes, "root", b, el_id)
  b.write_string("  let body = @svon.document_body()\n")
  b.write_string("  @svon.node_append_child(body, root)\n")
  b.write_string("}\n")
  b.to_string()
}

fn generate_script(script : String, b : StringBuilder) -> Unit {
  let raw_lines = script.split("\n")
  for line in raw_lines {
    let s = line.to_owned()
    let trimmed = s.trim().to_owned()
    let transformed = transform_line(trimmed)
    if transformed.length() > 0 {
      b.write_string("  ")
      b.write_string(transformed)
      b.write_string("\n")
    }
  }
}

fn transform_line(line : String) -> String {
  if line == "" {
    return ""
  }
  if line.has_prefix("//") {
    return line
  }
  let mut result = line
  result = result.replace_all(old="state(", new="@svon.state(")
  result = result.replace_all(old="derived(", new="@svon.derived(")
  result = result.replace_all(old="effect(", new="@svon.effect(")
  result
}

fn generate_nodes(
  nodes : Array[HtmlNode],
  parent : String,
  b : StringBuilder,
  el_id : Ref[Int],
) -> Unit {
  for i in 0..<nodes.length() {
    let node = nodes[i]
    match node {
      HtmlNode::Text(chunk) => generate_text(chunk, parent, b, el_id)
      HtmlNode::Element(el) => generate_element(el, parent, b, el_id)
    }
  }
}

fn generate_text(
  chunk : TextChunk,
  parent : String,
  b : StringBuilder,
  el_id : Ref[Int],
) -> Unit {
  let id = el_id.val
  el_id.val = id + 1
  let id_str = id.to_string()
  match chunk {
    TextChunk::Static(s) => {
      b <+ "  let t\{id_str} : @svon.DomNode = @svon.document_create_text_node(\"\{s}\")\n"
      b <+ "  @svon.node_append_child(\{parent}, t\{id_str})\n"
    }
    TextChunk::Expr(expr) => {
      b <+ "  let t\{id_str} : @svon.DomNode = @svon.document_create_text_node(\"\")\n"
      b <+ "  @svon.node_append_child(\{parent}, t\{id_str})\n"
      b <+ "        let _ = @svon.effect(fn() {\n"
      b <+ "    @svon.node_set_text_content(t\{id_str}, \{expr}.to_string())\n"
      b <+ "    Option::None\n"
      b <+ "  })\n"
    }
  }
}

fn generate_element(
  el : ElementNode,
  parent : String,
  b : StringBuilder,
  el_id : Ref[Int],
) -> Unit {
  let id = el_id.val
  el_id.val = id + 1
  let el_var = "el" + id.to_string()
  b <+ "  let \{el_var} : @svon.DomNode = @svon.document_create_element(\"\{el.tag}\")\n"

  for i in 0..<el.attributes.length() {
    let attr = el.attributes[i]
    match attr {
      Attribute::Static(name, value) => {
        b <+ "  @svon.node_set_attribute(\{el_var}, \"\{name}\", \"\{value}\")\n"
      }
      Attribute::Event(event, handler) => {
        b <+ "  @svon.node_add_event_listener(\{el_var}, \"\{event}\", \{handler})\n"
      }
      Attribute::Bind(attr_name, expr) => {
        b <+ "        let _ = @svon.effect(fn() {\n"
        b <+ "    @svon.node_set_attribute(\{el_var}, \"\{attr_name}\", \{expr}.to_string())\n"
        b <+ "    Option::None\n"
        b <+ "  })\n"
      }
    }
  }

  generate_nodes(el.children, el_var, b, el_id)

  b <+ "  @svon.node_append_child(\{parent}, \{el_var})\n"
}

fn generate_style_injection(css : String, b : StringBuilder) -> Unit {
  b.write_string("  let style_el : @svon.DomNode = @svon.document_create_element(\"style\")\n")
  let escaped = css.replace_all(old="\"", new="\\\"").replace_all(old="\n", new="\\n")
  b <+ "  @svon.node_set_text_content(style_el, \"\{escaped}\")\n"
  b.write_string("  let head = @svon.document_head()\n")
  b.write_string("  @svon.node_append_child(head, style_el)\n")
}
